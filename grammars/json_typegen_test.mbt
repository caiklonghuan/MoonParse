///|
// JSON 语法的 typegen 端到端测试
//
// 5.1：对 json_grammar 调用 generate_typed_api，断言关键内容
// 5.2：展示 CST 遍历模式，说明类型 API 的设计意图

// ─── 辅助 ───────────────────────────────────────────────────────────────────

///|
/// 解析 json_grammar DSL 并调用 generate_typed_api，返回生成源码。
fn gen_json_api() -> String {
  let grammar = match @grammar.parse_grammar(@grammars.json_grammar) {
    Success(g) => g
    Error(e) => {
      println("json_grammar parse failed: \{e.message}")
      panic()
    }
  }
  match @typegen.generate_typed_api(grammar, "json") {
    Ok(src) => src
    Err(e) => {
      println("generate_typed_api failed: \{e}")
      panic()
    }
  }
}

// ─── 5.1: 断言生成结果的关键内容 ─────────────────────────────────────────────

///|
test "json typegen / result is Ok" {
  let grammar = match @grammar.parse_grammar(@grammars.json_grammar) {
    Success(g) => g
    Error(e) => fail("json_grammar parse failed: \{e.message}")
  }
  match @typegen.generate_typed_api(grammar, "json") {
    Ok(_) => ()
    Err(e) => fail("generate_typed_api returned Err: \{e}")
  }
}

///|
test "json typegen / header present" {
  let src = gen_json_api()
  assert_true(src.has_prefix("// Auto-generated by MoonParse typegen."))
  assert_true(src.contains("// Grammar: json / json"))
}

///|
test "json typegen / enum Value generated" {
  let src = gen_json_api()
  // rule value 是 Choice → 生成 enum
  assert_true(src.contains("pub(all) enum Value"))
  // 各命名规则分支
  assert_true(src.contains("Object(@runtime.CstNode)"))
  assert_true(src.contains("Array(@runtime.CstNode)"))
  assert_true(src.contains("String(@runtime.CstNode)"))
  assert_true(src.contains("Number(@runtime.CstNode)"))
  // 字面量分支（"true"/"false"/"null"）
  assert_true(src.contains("LitTrue(@runtime.CstNode)"))
  assert_true(src.contains("LitFalse(@runtime.CstNode)"))
  assert_true(src.contains("LitNull(@runtime.CstNode)"))
}

///|
test "json typegen / struct types generated" {
  let src = gen_json_api()
  // Token / Alias 规则均生成含 _node 的 struct
  assert_true(src.contains("pub(all) struct Object"))
  assert_true(src.contains("pub(all) struct Dstring"))
  assert_true(src.contains("pub(all) struct Number"))
  assert_true(src.contains("_node : @runtime.CstNode"))
}

///|
test "json typegen / Value from_node accessor" {
  let src = gen_json_api()
  assert_true(
    src.contains(
      "Value::from_node(node : @runtime.CstNode, rule_name : String)",
    ),
  )
  // match branches for each variant
  assert_true(src.contains("\"object\" => Some(Value::Object(node))"))
  assert_true(src.contains("\"string\" => Some(Value::String(node))"))
  assert_true(src.contains("\"number\" => Some(Value::Number(node))"))
  assert_true(src.contains("\"lit_true\" => Some(Value::LitTrue(node))"))
}

///|
test "json typegen / Value node accessor" {
  let src = gen_json_api()
  assert_true(src.contains("Value::node(self : Value) -> @runtime.CstNode"))
  // 所有变体在 | 模式中合并
  assert_true(src.contains("Object(n)"))
  assert_true(src.contains("=> n"))
}

///|
test "json typegen / struct node and of accessors" {
  let src = gen_json_api()
  // Number 是 token，应有 node/of
  assert_true(src.contains("Number::node(self : Number)"))
  assert_true(src.contains("Number::of(node : @runtime.CstNode) -> Number"))
  assert_true(src.contains("Dstring::node(self : Dstring)"))
  assert_true(src.contains("Dstring::of(node : @runtime.CstNode) -> Dstring"))
}

///|
