      #|
      #|///|
      #|/// 将 CstNode 按规则名转换为 Value。
      #|/// rule_name 可由 `table.symbol_metadata[node.symbol].name` 获取。
      #|pub fn Value::from_node(node : @runtime.CstNode, rule_name : String) -> Value? {
      #|  match rule_name {
