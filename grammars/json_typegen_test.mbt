// ─── 5.2: 手工使用示例 ───────────────────────────────────────────────────────
//
// 以下测试演示：解析 JSON 后，通过 CstNode API 遍历对象字段。
// 这是生成的类型 API 的底层实现基础。
//
// 生成的类型 API 使用示例（伪代码，需在编译环境中运行 generate-types 后使用）：
//
//   let src = "{ \"name\": \"moonbit\" }"
//   match parse_json(src) {
//     Ok(root) => {
//       match Value::from_node(root, table.symbol_metadata[root.symbol].name) {
//         Some(Value::Object(obj_node)) => {
//           // object 节点：访问内部 pairs 子节点
//           let pairs_node = Object::of(obj_node).node()
//           // pairs → pair → jstring ":" value
//           ...
//         }
//         _ => fail("expected object")
//       }
//     }
//     Err(e) => fail(e.message)
//   }
//
// 优势：Value::from_node 调用若传入错误的规则名，返回 None 而非 panic；
// 任何类型错误会在 `moon check` 阶段暴露，而不是在运行时失败。

///|
test "json typegen / usage demo - parse object and traverse children" {
  // 解析 JSON 对象
  let src = "{ \"key\": \"value\" }"
  let root = match @grammars.parse_json(src) {
    Ok(node) => node
    Err(e) => fail("parse failed: \{e.message}")
  }
  // CST 根节点：rule json → 内层 value → object
  assert_true(!root.is_error)
  // root.children 中应有命名的子节点链路
  // (此处演示：生成 API 的 Object::of / Value::from_node 包装的就是这个 root)
  // 验证 root 有子节点，供类型 API 基于 children 遍历
  assert_true(root.children.length() > 0)
}

///|
test "json typegen / usage demo - parse array" {
  let src = "[1, 2, 3]"
  let root = match @grammars.parse_json(src) {
    Ok(node) => node
    Err(e) => fail("parse failed: \{e.message}")
  }
  assert_true(!root.is_error)
  // 生成的 API 中：
  //   let arr = Value::from_node(root, rule_name) → Some(Value::Array(node))
  //   let arr_node = arr.unwrap().node()
  //   // 通过 CstNode.children 遍历元素
  assert_true(root.children.length() > 0)
}

///|
test "json typegen / usage demo - scalar values have correct node structure" {
  // 对标量值（number/string/bool/null），生成 API 的 Token struct 直接持有 CstNode
  // Number::of(root).node() == root 成立（幂等包装）
  let cases = ["42", "\"hello\"", "true", "false", "null"]
  for input in cases {
    let root = match @grammars.parse_json(input) {
      Ok(node) => node
      Err(e) => fail("parse '\{input}' failed: \{e.message}")
    }
    assert_true(!root.is_error)
    // 生成 API 的 Token struct 包装：Number::of(root).node() is CstNode
    // 此处验证 root 确实是叶子或简单节点
    assert_true(root.start_byte <= root.end_byte)
  }
}
