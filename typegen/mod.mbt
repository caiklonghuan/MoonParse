///|
// typegen 对外统一入口

// ── 方案 B：与 ParseTable 解耦 ────────────────────────────────────────────────
//
// 阶段三 3.2 决策：采用**方案 B**（保持解耦），不在 ParseTable 中嵌入 TypeSchema。
//
// 理由：
// 1. `typegen` 包依赖 `grammar`，而 `tablegen` 不应反向依赖 `typegen`，
//    避免形成循环依赖。
// 2. `ParseTable.symbol_metadata` 已通过 `field_slots : Array[String]`
//    携带字段布局，足够运行时按名定位子节点，无需完整 TypeSchema。
// 3. 需要 TypeSchema 的用户（代码生成、IDE 插件等）直接调用本包的
//    `infer_grammar(grammar)` 即可得到，无需经由 ParseTable 获取。
//
// 最终公开接口：
// - `generate_typed_api(grammar, module_name) -> Result[String, String]`
//   （完整 .mbt 文件生成）
// - `infer_grammar(grammar) -> TypeSchema`
//   （仅需类型形状时使用，等价于 generate_type_schema(grammar)）
// ─────────────────────────────────────────────────────────────────────────────

///|
/// 模块头注释模板
fn make_header(grammar_name : String) -> String {
  "// Auto-generated by MoonParse typegen. DO NOT EDIT.\n// Grammar: " +
  grammar_name +
  "\n"
}

///|
/// 从 Grammar 一步生成完整的类型安全 CST API 源码。
///
/// 返回一个可直接写入 `.mbt` 文件的 MoonBit 源码字符串，包含：
/// - 模块头注释
/// - 所有命名规则的类型定义（struct / enum）
/// - 所有类型的访问器函数（`of`、`node`、字段访问器、`from_node`）
///
/// `module_name` 用于头部注释中标识目标模块（不影响生成代码的命名空间）。
///
/// 若 grammar 规则表为空，返回 `Err`。
pub fn generate_typed_api(
  grammar : @grammar.Grammar,
  module_name : String,
) -> Result[String, String] {
  if grammar.rules.is_empty() {
    return Err("generate_typed_api: grammar has no rules")
  }
  let schema = infer_grammar(grammar)
  if schema.size() == 0 {
    return Err(
      "generate_typed_api: no user-visible rules after filtering (all rules are @inline / @hide / anonymous)",
    )
  }
  let header = make_header(
    module_name + " / " + grammar.start.unwrap_or("(unknown)"),
  )
  let type_defs = emit_type_defs(schema)
  let accessors = emit_accessors(schema)
  Ok(header + type_defs + "\n" + accessors)
}
